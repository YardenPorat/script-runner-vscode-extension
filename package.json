{
  "name": "monorepo-script-runner",
  "displayName": "Monorepo Script Runner",
  "description": "Discover, group, annotate and run package.json scripts across a monorepo. Config persists to a committable JSON file.",
  "version": "0.18.0",
  "publisher": "yardenporat",
  "author": "Yarden Porat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YardenPorat/script-runner-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/YardenPorat/script-runner-vscode-extension/issues"
  },
  "homepage": "https://github.com/YardenPorat/script-runner-vscode-extension#readme",
  "engines": {
    "vscode": "^1.93.0"
  },
  "icon": "icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "monorepo",
    "npm scripts",
    "package.json",
    "task runner",
    "pnpm",
    "yarn",
    "workspace"
  ],
  "main": "./out-js/extension.js",
  "activationEvents": [
    "workspaceContains:**/package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scriptRunner",
          "title": "Script Runner",
          "icon": "$(run-all)"
        }
      ]
    },
    "views": {
      "scriptRunner": [
        {
          "id": "scriptRunner.scripts",
          "type": "webview",
          "name": "Scripts",
          "icon": "$(run-all)"
        }
      ]
    },
    "commands": [
      {
        "command": "scriptRunner.refresh",
        "title": "Refresh Scripts",
        "category": "Script Runner",
        "icon": "$(refresh)"
      },
      {
        "command": "scriptRunner.search",
        "title": "Search Scripts…",
        "category": "Script Runner",
        "icon": "$(search)"
      },
      {
        "command": "scriptRunner.run",
        "title": "Run Script",
        "category": "Script Runner",
        "icon": "$(play)"
      },
      {
        "command": "scriptRunner.assignGroup",
        "title": "Assign Group…",
        "category": "Script Runner",
        "icon": "$(folder)"
      },
      {
        "command": "scriptRunner.editComment",
        "title": "Edit Comment…",
        "category": "Script Runner",
        "icon": "$(comment)"
      },
      {
        "command": "scriptRunner.renameScript",
        "title": "Rename Script…",
        "category": "Script Runner",
        "icon": "$(edit)"
      },
      {
        "command": "scriptRunner.openConfig",
        "title": "Open Config File",
        "category": "Script Runner",
        "icon": "$(gear)"
      },
      {
        "command": "scriptRunner.openInEditor",
        "title": "Open in Editor",
        "category": "Script Runner",
        "icon": "$(open-preview)"
      },
      {
        "command": "scriptRunner.renameGroup",
        "title": "Rename Group…",
        "category": "Script Runner"
      },
      {
        "command": "scriptRunner.removeFromGroup",
        "title": "Remove from Group",
        "category": "Script Runner"
      },
      {
        "command": "scriptRunner.copyCommand",
        "title": "Copy Command",
        "category": "Script Runner",
        "icon": "$(copy)"
      },
      {
        "command": "scriptRunner.copyCommandName",
        "title": "Copy Command Name",
        "category": "Script Runner",
        "icon": "$(copy)"
      },
      {
        "command": "scriptRunner.openTerminalHere",
        "title": "Open Terminal in Working Dir",
        "category": "Script Runner",
        "icon": "$(terminal)"
      },
      {
        "command": "scriptRunner.undo",
        "title": "Undo Last Change",
        "category": "Script Runner",
        "icon": "$(discard)"
      },
      {
        "command": "scriptRunner.redo",
        "title": "Redo Last Change",
        "category": "Script Runner",
        "icon": "$(redo)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "scriptRunner.search",
          "when": "view == scriptRunner.scripts",
          "group": "navigation@0"
        },
        {
          "command": "scriptRunner.refresh",
          "when": "view == scriptRunner.scripts",
          "group": "navigation@1"
        },
        {
          "command": "scriptRunner.openInEditor",
          "when": "view == scriptRunner.scripts",
          "group": "navigation@2"
        },
        {
          "command": "scriptRunner.openConfig",
          "when": "view == scriptRunner.scripts",
          "group": "navigation@3"
        }
      ],
      "webview/context": [
        {
          "command": "scriptRunner.renameScript",
          "when": "webviewSection == 'srScript'",
          "group": "0_edit@1"
        },
        {
          "command": "scriptRunner.assignGroup",
          "when": "webviewSection == 'srScript'",
          "group": "0_edit@2"
        },
        {
          "command": "scriptRunner.editComment",
          "when": "webviewSection == 'srScript'",
          "group": "0_edit@3"
        },
        {
          "command": "scriptRunner.removeFromGroup",
          "when": "webviewSection == 'srScript'",
          "group": "0_edit@4"
        },
        {
          "command": "scriptRunner.copyCommand",
          "when": "webviewSection == 'srScript'",
          "group": "1_copy@1"
        },
        {
          "command": "scriptRunner.copyCommandName",
          "when": "webviewSection == 'srScript'",
          "group": "1_copy@2"
        },
        {
          "command": "scriptRunner.openTerminalHere",
          "when": "webviewSection == 'srScript'",
          "group": "2_terminal@1"
        },
        {
          "command": "scriptRunner.renameGroup",
          "when": "webviewSection == 'srGroup'",
          "group": "0_edit@1"
        }
      ]
    },
    "configuration": {
      "title": "Script Runner",
      "properties": {
        "scriptRunner.configFile": {
          "type": "string",
          "default": "script-runner.config.json",
          "description": "Path of the committable config file, relative to the workspace root."
        },
        "scriptRunner.packageManager": {
          "type": "string",
          "enum": [
            "auto",
            "npm",
            "yarn",
            "pnpm",
            "bun"
          ],
          "default": "auto",
          "description": "Package manager used to run scripts. 'auto' detects from lockfiles."
        },
        "scriptRunner.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/.git/**"
          ],
          "description": "Glob patterns excluded when scanning for package.json files."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p tsconfig.test.json && node --test \"out-test/test/*.test.js\"",
    "vscode:prepublish": "npm run compile",
    "package": "mkdir -p out-packaged && vsce package -o out-packaged/",
    "publish": "vsce publish",
    "install-latest": "code --install-extension \"$(ls -t out-packaged/*.vsix | head -1)\" --force"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.4.0"
  }
}
